rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images live under productImages/<filename>
    match /productImages/{fileName} {
      // Read: public (anyone can view the image)
      allow read: if true;
      // Write: only admins (same check as Firestore)
      allow write: if request.auth != null
                   && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
  }
}